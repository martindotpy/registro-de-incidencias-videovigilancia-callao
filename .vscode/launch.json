{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web 🐞",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev --host",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "localhost:(\\d+)",
        "uriFormat": "http://localhost:%s"
      }
    }
  ]
}
